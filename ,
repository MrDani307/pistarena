TriggerCircle.Filled = false
TriggerCircle.Color = Color3.fromRGB(255, 0, 0)
TriggerCircle.Visible = false

local function trackSpawn(char)
    local p = Players:GetPlayerFromCharacter(char)
    if p then spawnTimes[p.UserId] = tick() end
end

for _, p in pairs(Players:GetPlayers()) do
    if p.Character then trackSpawn(p.Character) end
    p.CharacterAdded:Connect(trackSpawn)
end

Players.PlayerAdded:Connect(function(p)
    p.CharacterAdded:Connect(trackSpawn)
end)

local dragging, inputObject = false, nil
local moveVector = Vector3.new(0, 0, 0)
local startPos = Vector2.new(0, 0)

JumpButton.MouseButton1Down:Connect(function()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
end)
JumpButton.MouseButton1Up:Connect(function()
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, game)
end)

CaptureArea.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
        dragging, inputObject, startPos = true, input, Vector2.new(input.Position.X, input.Position.Y)
        Base.Position, Base.Visible, Stick.Visible = UDim2.new(0, startPos.X - 20, 0, startPos.Y - 20), true, true
        for _, d in pairs(dots) do d.Visible = true end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == inputObject then
        local currentPos = Vector2.new(input.Position.X, input.Position.Y)
        local diff = currentPos - startPos
        if diff.Magnitude > 0 then
            Stick.Position = UDim2.new(0, currentPos.X - 22.5, 0, currentPos.Y - 22.5)
            for i, dot in pairs(dots) do
                local dotPos = startPos + (diff * (i/7))
                dot.Position = UDim2.new(0, dotPos.X - (dot.Size.X.Offset/2), 0, dotPos.Y - (dot.Size.Y.Offset/2))
            end
            local dir = diff.Unit
            moveVector = Vector3.new(dir.X, 0, dir.Y)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input == inputObject then
        dragging, Base.Visible, Stick.Visible = false, false, false
        for _, d in pairs(dots) do d.Visible = false end
        moveVector = Vector3.new(0, 0, 0)
    end
end)

