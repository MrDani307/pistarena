local lastClick = 0
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    TriggerCircle.Radius = Settings.TriggerFOV
    TriggerCircle.Position = center
    TriggerCircle.Visible = Settings.ShowTriggerFOV

    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")

        if aaEnabled and root and hum then
            if hum.FloorMaterial == Enum.Material.Air then
                hum.AutoRotate = false
                root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(math.random(-180, 180)), 0)
            else
                hum.AutoRotate = true
            end
        end

        if hum and ScreenGui.Enabled then hum:Move(moveVector, true) end

        local target = GetClosestTarget()
        if target and target.Character then
            local part = target.Character:FindFirstChild(Settings.AimPart) or target.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if Settings.Aimbot then
                    if not lastView then lastView = Camera.CFrame end
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
                end
                
                if Settings.Trigger then
                    local screenPoint, onScreen = Camera:WorldToViewportPoint(part.Position)
                    local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - center).Magnitude
                    
                    if dist < Settings.TriggerFOV and tick() - lastClick >= 0.05 then
                        local sTime = spawnTimes[target.UserId] or 0
                        if tick() - sTime >= Settings.SpawnDelay then
                            VirtualInputManager:SendMouseButtonEvent(Settings.ClickX, Settings.ClickY, 0, true, game, 1)
                            task.delay(0.01, function() VirtualInputManager:SendMouseButtonEvent(Settings.ClickX, Settings.ClickY, 0, false, game, 1) end)
                            lastClick = tick()
                        end
                    end
                end
            end
        else
            if lastView and Settings.Aimbot then
                Camera.CFrame = lastView
                lastView = nil
            end
        end
    end
end)
