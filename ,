local function IsVisible(part)
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    rayParams.FilterDescendantsInstances = {Player.Character, Camera}
    local result = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * (part.Position - Camera.CFrame.Position).Magnitude, rayParams)
    return result == nil or result.Instance:IsDescendantOf(part.Parent)
end

local function GetClosestTarget()
    local target, shortestDist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= Player and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
            if Settings.TeamCheck and p.Team == Player.Team and p.Team ~= nil then continue end
            local part = p.Character:FindFirstChild(Settings.AimPart) or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if Settings.WallCheck and not IsVisible(part) then continue end
                local dist = (part.Position - Camera.CFrame.Position).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    target = p
                end
            end
        end
    end
    return target
end

task.spawn(function()
    while true do
        for _, player in ipairs(Players:GetPlayers()) do
            if highlightsEnabled and player ~= Player and player.Character then
                local highlight = player.Character:FindFirstChild("DeltaHighlight") or Instance.new("Highlight", player.Character)
                highlight.Name = "DeltaHighlight"
                highlight.FillTransparency = 0.5
                highlight.OutlineTransparency = 0
                if player.Team == Player.Team and player.Team ~= nil then
                    highlight.FillColor = Color3.fromRGB(0, 0, 255)
                    highlight.OutlineColor = Color3.fromRGB(0, 0, 255)
                else
                    highlight.FillColor = Color3.fromRGB(255, 0, 0)
                    highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                end
            else
                local h = player.Character and player.Character:FindFirstChild("DeltaHighlight")
                if h then h:Destroy() end
            end
        end
        task.wait(0.3)
    end
end)

local dragging, inputObject = false, nil
local moveVector = Vector3.new(0, 0, 0)
local startPos = Vector2.new(0, 0)

JumpButton.MouseButton1Down:Connect(function()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, game)
end)
JumpButton.MouseButton1Up:Connect(function()
