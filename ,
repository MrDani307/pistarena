RunService.RenderStepped:Connect(function()
    local char = Player.Character
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    
    TriggerCircle.Radius = Settings.TriggerFOV
    TriggerCircle.Position = center
    TriggerCircle.Visible = Settings.ShowTriggerFOV

    if tpEnabled then
        Player.CameraMaxZoomDistance = 999999
        Player.CameraMinZoomDistance = 0
        Player.CameraMode = Enum.CameraMode.Classic
    else
        Player.CameraMaxZoomDistance = 0.5
        Player.CameraMinZoomDistance = 0.5
    end

    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")

        if aaEnabled and root and hum then
            if hum.FloorMaterial == Enum.Material.Air then
                hum.AutoRotate = false
                root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(math.random(-180, 180)), 0)
            else
                hum.AutoRotate = true
            end
        end

        if hum and ScreenGui.Enabled then hum:Move(moveVector, true) end

        if Settings.Aimbot or Settings.Trigger then
            local target = nil
            local shortestDist = math.huge
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= Player and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                    if not Settings.TeamCheck or p.Team ~= Player.Team then
                        local part = p.Character:FindFirstChild(Settings.AimPart) or p.Character:FindFirstChild("HumanoidRootPart")
                        if part then
                            local rayParams = RaycastParams.new()
                            rayParams.FilterType = Enum.RaycastFilterType.Exclude
                            rayParams.FilterDescendantsInstances = {char, Camera}
                            local res = workspace:Raycast(Camera.CFrame.Position, (part.Position - Camera.CFrame.Position).Unit * (part.Position - Camera.CFrame.Position).Magnitude, rayParams)
                            if not res or res.Instance:IsDescendantOf(part.Parent) then
                                local dist = (part.Position - Camera.CFrame.Position).Magnitude
                                if dist < shortestDist then shortestDist = dist; target = p end
                            end
                        end
                    end
                end
            end

            if target and target.Character then
                local part = target.Character:FindFirstChild(Settings.AimPart) or target.Character:FindFirstChild("HumanoidRootPart")
                if Settings.Aimbot then Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position) end
                if Settings.Trigger and tick() - (spawnTimes[target.UserId] or 0) >= Settings.SpawnDelay then
                    local screenPoint, onScreen = Camera:WorldToViewportPoint(part.Position)
                    if onScreen and (Vector2.new(screenPoint.X, screenPoint.Y) - center).Magnitude < Settings.TriggerFOV then
                        VirtualInputManager:SendMouseButtonEvent(Settings.ClickX, Settings.ClickY, 0, true, game, 1)
                        task.delay(0.01, function() VirtualInputManager:SendMouseButtonEvent(Settings.ClickX, Settings.ClickY, 0, false, game, 1) end)
                    end
                end
            end
        end
    end
end)
