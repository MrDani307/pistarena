    Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
    table.insert(dots, dot)
end

local Stick = Instance.new("Frame", ScreenGui)
Stick.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
