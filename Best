-- Main Runtime Loop
local lastClick = 0
RunService.RenderStepped:Connect(function()
    local char = Player.Character
    local viewportSize = Camera.ViewportSize
    local center = Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)

    if char and char:FindFirstChild("HumanoidRootPart") then
        local root = char.HumanoidRootPart
        local hum = char:FindFirstChildOfClass("Humanoid")

        if autoFarmEnabled then
            local currentTime = tick()
            if not currentTPTarget or not currentTPTarget.Parent or currentTPTarget.Humanoid.Health <= 0 then
                local pTarget = GetClosestAny()
                local newName = pTarget and pTarget.Name or ""
                if newName ~= lastTargetName and newName ~= "" then
                    lastTargetName = newName
                    WindUI:Notify({ Title = "Target Changed", Content = "→ " .. newName, Duration = 2 })
                end
                currentTPTarget = pTarget and pTarget.Character or nil
                targetStartTime = currentTime
            elseif (currentTime - targetStartTime) > 3 then
                local pTarget = GetFarthestAny()
                local newName = pTarget and pTarget.Name or ""
                if newName ~= lastTargetName and newName ~= "" then
                    lastTargetName = newName
                    WindUI:Notify({ Title = "Target Changed", Content = "→ " .. newName, Duration = 2 })
                end
                currentTPTarget = pTarget and pTarget.Character or nil
                targetStartTime = currentTime
            end

            if currentTPTarget and currentTPTarget:FindFirstChild("HumanoidRootPart") then
                local tRoot = currentTPTarget.HumanoidRootPart
                root.CFrame = tRoot.CFrame * CFrame.new(0, 2, 3)
                root.AssemblyLinearVelocity = Vector3.new(0,0,0)
            end
        end

        local combatTarget = GetClosest360()
        if combatTarget and combatTarget.Character then
            local part = combatTarget.Character:FindFirstChild(Settings.AimPart) or combatTarget.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if Settings.Aimbot then
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, part.Position)
                end

                if Settings.Trigger and not triggerPaused then
                    local screenPoint, onScreen = Camera:WorldToViewportPoint(part.Position)
                    local dist = (Vector2.new(screenPoint.X, screenPoint.Y) - center).Magnitude

                    if onScreen and dist < Settings.TriggerFOV and tick() - lastClick >= 0.08 then
                        local sTime = spawnTimes[combatTarget.UserId] or 0
                        if tick() - sTime >= Settings.SpawnDelay then
                            VirtualInputManager:SendMouseButtonEvent(viewportSize.X * 0.85, viewportSize.Y * 0.75, 0, true, game, 1)
                            task.delay(0.01, function()
                                VirtualInputManager:SendMouseButtonEvent(viewportSize.X * 0.85, viewportSize.Y * 0.75, 0, false, game, 1)
                            end)
                            lastClick = tick()
                            killCount = killCount + 1
                            if killCountLabel then
                                killCountLabel.Title = "Kills: " .. killCount
                            end
                        end
                    end
                end
            end
        end

        if not autoFarmEnabled and hum and ScreenGui.Enabled then
            hum:Move(moveVector, true)
        end
    end
end)

