local function SaveSettings()
    local data = {
        masterEnabled = masterEnabled,
        highlightsEnabled = highlightsEnabled,
        aaEnabled = aaEnabled,
        noclipEnabled = noclipEnabled,
        autoFarmEnabled = autoFarmEnabled,
        autoExec = autoExec,
        Aimbot = Settings.Aimbot,
        Trigger = Settings.Trigger,
        TriggerFOV = Settings.TriggerFOV,
        ShowTriggerFOV = Settings.ShowTriggerFOV,
        TeamCheck = Settings.TeamCheck,
        SpawnDelay = Settings.SpawnDelay
    }
    pcall(function() writefile(FileName, HttpService:JSONEncode(data)) end)
end

local function LoadSettings()
    if isfile(FileName) then
        local ok, data = pcall(function() return HttpService:JSONDecode(readfile(FileName)) end)
        if ok and data then
            masterEnabled = data.masterEnabled or false
            highlightsEnabled = data.highlightsEnabled ~= nil and data.highlightsEnabled or true
            aaEnabled = data.aaEnabled or false
            noclipEnabled = data.noclipEnabled or false
            autoFarmEnabled = data.autoFarmEnabled or false 
            autoExec = data.autoExec or false
            Settings.Aimbot = data.Aimbot or false
            Settings.Trigger = data.Trigger ~= nil and data.Trigger or true
            Settings.TriggerFOV = data.TriggerFOV or 10
            Settings.ShowTriggerFOV = data.ShowTriggerFOV or false
            Settings.TeamCheck = data.TeamCheck or false
            Settings.SpawnDelay = data.SpawnDelay or 1.2
        end
    end
end

