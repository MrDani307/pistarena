task.spawn(function()
    while true do
        for _, p in ipairs(Players:GetPlayers()) do
            if highlightsEnabled and p ~= Player and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                local h = p.Character:FindFirstChild("DeltaHighlight") or Instance.new("Highlight", p.Character)
